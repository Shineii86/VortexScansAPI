{
  "version": 2,
  "builds": [
    {
      "src": "src/app/**/*.js",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/manga",
      "dest": "/src/app/api/manga/route.js"
    },
    {
      "src": "/api/manga/search",
      "dest": "/src/app/api/manga/route.js"
    },
    {
      "src": "/api/manga/:slug",
      "dest": "/src/app/api/manga/[slug]/route.js"
    },
    {
      "src": "/api/genres",
      "dest": "/src/app/api/genres/route.js"
    },
    {
      "src": "/api/status",
      "dest": "/src/app/api/status/route.js"
    }
  ]
}
